# ── Backend: Server ──────────────────────────────
APP_NAME=URL Shortener
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ── Backend: CORS ────────────────────────────────
# Comma-separated. Must include wherever the frontend is actually served from.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://<EC2_PUBLIC_IP>

# ── Backend: Database ────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=urlshortener
DATABASE_USER=postgres
DATABASE_PASSWORD=changeme
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Backend: Redis ───────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=86400
REDIS_MAXMEMORY=256mb

# ── Backend: URL Config ──────────────────────────
BASE_URL=http://<EC2_PUBLIC_IP>
SHORT_CODE_LENGTH=6
CUSTOM_ALIAS_MAX_LENGTH=50

# ── Backend: Feature Flags ───────────────────────
ENABLE_QR_CODE=True
ENABLE_ANALYTICS=True
ENABLE_CUSTOM_ALIAS=True
ENABLE_RATE_LIMITING=False

# ── Backend: Rate Limiting ───────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ── Backend: Logging ──────────────────────────────
LOG_LEVEL=INFO

# ── Frontend (consumed by entrypoint.sh at container start) ──
FRONTEND_BASE_URL=http://<EC2_PUBLIC_IP>
API_BASE_URL=http://<EC2_PUBLIC_IP>
ENABLE_QR_CODE=True

# ── Postgres image init vars (must match DATABASE_* above) ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=urlshortener